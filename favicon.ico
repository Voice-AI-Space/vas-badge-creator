<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 1200" width="1200" height="1200">
  <!-- White card -->
  <rect x="0" y="0" width="1200" height="1200" fill="#ffffff"/>
  <!-- Thin black frame -->
  <rect x="116" y="116" width="968" height="968" fill="none" stroke="#000000" stroke-width="12"/>
  <!-- Black rounded inner square -->
  <rect x="250" y="262" width="700" height="700" rx="46" ry="46" fill="#000000"/>
  <!-- Two white "eye" rings -->
  <circle cx="500" cy="600" r="80" fill="none" stroke="#ffffff" stroke-width="22"/>
  <circle cx="706" cy="600" r="80" fill="none" stroke="#ffffff" stroke-width="22"/>
</svg>
